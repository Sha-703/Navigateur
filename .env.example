# ============================================================
# Configuration pour le serveur WAPI
# ============================================================

# Port sur lequel le serveur écoute
# En production (Render), ce port est assigné automatiquement
PORT=3000

# Environnement : development ou production
NODE_ENV=development

# URL du client Electron (pour CORS en production)
# Exemple: https://mon-app.electron.com ou laissez vide pour localhost
CLIENT_URL=
